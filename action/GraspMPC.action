# GraspMPC action - Execute grasp sequence with MPC reactive control
#
# This action provides feedback during grasp execution, allowing
# monitoring of the current phase and progress.

# Goal
geometry_msgs/Pose target_pose          # Grasp pose (end-effector at object)
string object_name                       # Object to grasp (must exist in obstacle manager)
geometry_msgs/Vector3 pre_grasp_offset  # Approach offset (default: [0,0,0.1])
geometry_msgs/Vector3 post_grasp_offset # Retreat offset (default: [0,0,0.15])

---
# Result
bool success
string message
float64 execution_time                   # Total execution time in seconds

---
# Feedback
string current_phase                     # Current grasp phase: "APPROACH", "GRASP", "ATTACHED", "RETREAT"
float64 phase_progress                   # Progress in current phase (0.0 to 1.0)
float64 pose_error                       # Current pose error in meters
int32 mpc_iteration                      # Current MPC iteration number
