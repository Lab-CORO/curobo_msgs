sensor_msgs/JointState start_pose

geometry_msgs/Pose target_pose
geometry_msgs/Pose[] target_poses  # Single pose or multiple waypoints for multi-point planning
float64[] target_joint_positions  # Target joint configuration for joint-space planning
int8[] trajectory_constraints # [theta_x, theta_y, theta_z, x, y, z]
int8[] trajectories_contraints # Flattened: [theta_x0, theta_y0, theta_z0, x0, y0, z0, theta_x1, theta_y1, theta_z1, x1, y1, z1, ...]

---

bool success
string message
sensor_msgs/JointState[] trajectory  # Trajectory waypoints (position, velocity)
float64 dt  # Time step between waypoints (seconds)